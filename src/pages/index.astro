---
import Footer from "../components/Footer.astro";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OnTask Logistics — Structured Courier Routes, Philadelphia</title>
    <meta
      name="description"
      content="OnTask Logistics provides scheduled, structured courier routes for offices, clinics, and professional practices across Philadelphia and surrounding counties."
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/ontask-favicon-main.png"
    />
    <link rel="apple-touch-icon" href="/ontask-favicon-main.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --navy: #0b1530;
        --navy-soft: #151f3a;
        --navy-subtle: #f4f6fb;
        --orange: #ff8a3c;
        --orange-soft: #ffb07a;
        --text-main: #111827;
        --text-muted: #374151;
        --border-subtle: #e1e5f0;
        --bg-body: #F9FAFB;
        --shadow-soft: 0 18px 45px rgba(10, 18, 40, 0.16);
        --radius-lg: 18px;
        --radius-md: 12px;
        --radius-pill: 999px;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background: var(--bg-body);
        color: var(--text-main);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      img {
        max-width: 100%;
        display: block;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* Layout */
      .page {
        min-height: 100vh;
        background: var(--bg-body);
      }

      .shell {
        max-width: 1120px;
        margin: 0 auto;
        padding: 56px 32px 128px;
      }

      /* NAV */
      .nav {
        position: sticky;
        top: 0;
        z-index: 40;
        backdrop-filter: blur(18px);
        background: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.95),
          rgba(255, 255, 255, 0.88)
        );
        border-bottom: 1px solid rgba(225, 229, 240, 0.7);
      }

      .nav-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 12px 20px 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        display: flex;
        align-items: center;
        flex-shrink: 0;
      }

      .brand img {
        display: block;
        height: 78px;
        width: auto;
      }

      .nav-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 28px;
        flex: 1;
      }

      .nav-link {
        font-size: 0.86rem;
        color: var(--text-muted);
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .nav-link:hover {
        color: var(--navy);
      }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 36px;
        padding: 8px 28px;
        white-space: nowrap;
        border-radius: var(--radius-pill);
        border: 1px solid transparent;
        background: #F36B2A;
        color: #ffffff;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        box-shadow: 0 1px 4px rgba(243, 107, 42, 0.2);
        cursor: pointer;
      }

      .nav-cta:hover {
        background: #f57a3d;
        filter: brightness(1.02);
      }

      .nav-toggle {
        display: none;
        width: 32px;
        height: 32px;
        border-radius: 999px;
        border: 1px solid var(--border-subtle);
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background: #ffffff;
      }

      .nav-toggle-bars {
        width: 16px;
        height: 13px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .nav-toggle-bars span {
        display: block;
        height: 2px;
        border-radius: 10px;
        background: #1a223a;
      }

      .nav-menu-mobile {
        display: none;
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 20px 12px;
      }

      .nav-menu-mobile-inner {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 10px 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(225, 229, 240, 0.9);
        background: rgba(255, 255, 255, 0.98);
      }

      .nav-menu-mobile a {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      .nav-menu-mobile a:hover {
        color: var(--navy);
      }

      /* HERO */
      .hero {
        padding-top: 128px;
        padding-bottom: 104px;
        background: linear-gradient(to bottom, #f8fafc, #ffffff);
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 2.5fr);
        gap: 72px;
        align-items: stretch;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 4px 10px 4px 5px;
        border-radius: var(--radius-pill);
        background: rgba(11, 21, 48, 0.03);
        border: 1px solid rgba(225, 229, 240, 0.9);
        margin-bottom: 28px;
      }

      .eyebrow-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 2px 8px;
        border-radius: 999px;
        background: rgba(11, 21, 48, 0.92);
        color: #ffffff;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 600;
      }

      .eyebrow-text {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-weight: 500;
      }

      .hero-title {
        font-size: clamp(2.7rem, 3.7vw, 3.25rem);
        letter-spacing: -0.035em;
        line-height: 1.18;
        color: var(--navy);
        margin-bottom: 40px;
        min-width: min(100%, 18rem);
        max-width: 26rem;
      }

      .hero-body {
        font-size: 0.98rem;
        color: var(--text-muted);
        max-width: 36rem;
        margin-bottom: 48px;
        line-height: 1.76;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 18px;
        margin-top: 8px;
        margin-bottom: 48px;
      }

      .hero-actions-note {
        font-size: 0.86rem;
        color: rgba(55, 65, 81, 0.85);
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 11px 22px;
        border-radius: var(--radius-pill);
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.94rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: linear-gradient(135deg, var(--orange), #ff9f5c);
        color: #ffffff;
        box-shadow: 0 16px 40px rgba(255, 138, 60, 0.38);
      }

      .btn-primary:hover {
        filter: brightness(1.03);
        transform: translateY(-1px);
      }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 11px 18px;
        border-radius: var(--radius-pill);
        border: 1px solid var(--border-subtle);
        background: #ffffff;
        color: var(--text-main);
        font-weight: 500;
        font-size: 0.9rem;
        cursor: pointer;
      }

      .btn-secondary:hover {
        border-color: #c9cfdd;
        background: #f7f8fc;
      }

      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 20px;
        margin-bottom: 40px;
      }

      .hero-meta-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #36c27c;
        box-shadow: 0 0 0 4px rgba(54, 194, 124, 0.25);
      }

      .hero-panel {
        position: relative;
        border-radius: var(--radius-lg);
        padding: 20px 20px 18px;
        background: #ffffff;
        color: var(--text-main);
        box-shadow: 0 10px 30px rgba(10, 18, 40, 0.08);
        overflow: hidden;
        align-self: flex-start;
      }

      .hero-panel::after {
        content: "";
        position: absolute;
        inset: 1px;
        border-radius: calc(var(--radius-lg) - 1px);
        border: 1px solid rgba(255, 255, 255, 0.04);
        pointer-events: none;
      }

      .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
      }

      .panel-label {
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        font-weight: 500;
        color: rgba(21, 29, 60, 0.9);
        text-transform: uppercase;
      }

      .panel-pill {
        font-size: 0.7rem;
        padding: 3px 10px;
        border-radius: var(--radius-pill);
        background: rgba(11, 232, 129, 0.12);
        color: #1c9f69;
        border: 1px solid rgba(94, 255, 188, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .route-card {
        margin-top: 6px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(20, 32, 80, 0.98), #111a3d);
        padding: 16px 16px 14px;
        border: 1px solid rgba(230, 235, 255, 0.2);
      }

      .route-heading {
        font-size: 0.86rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #f6f7ff;
        margin-bottom: 6px;
      }

      .route-grid {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .route-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        padding: 4px 0;
        border-top: 1px solid rgba(198, 207, 245, 0.32);
      }

      .route-row:first-of-type {
        border-top: none;
      }

      .route-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(201, 210, 246, 0.9);
      }

      .route-value {
        font-size: 0.8rem;
        color: rgba(234, 239, 255, 0.98);
        text-align: right;
      }

      .panel-footnote {
        margin-top: 14px;
        font-size: 0.7rem;
        color: var(--text-muted);
      }

      .panel-footnote strong {
        color: var(--navy);
        font-weight: 600;
      }

      /* SECTIONS */
      .section {
        padding-top: 96px;
        padding-bottom: 64px;
      }

      #consultation {
        margin-top: 64px;
      }

      .section--muted {
        background: #f8fafc;
      }

      .section-header {
        margin-bottom: 28px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .section-eyebrow {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--text-muted);
      }

      .section-title {
        font-size: 1.4rem;
        letter-spacing: -0.02em;
        color: var(--navy);
      }

      .section-body {
        font-size: 0.96rem;
        color: var(--text-muted);
        max-width: 36rem;
        line-height: 1.76;
      }

      /* HOW IT WORKS */
      .process {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 28px;
        margin-top: 24px;
      }

      .process-card {
        border-radius: var(--radius-md);
        border: 1px solid rgba(225, 229, 240, 0.9);
        background: #ffffff;
        padding: 18px 18px 16px;
      }

      .process-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--text-muted);
      }

      .process-number {
        width: 20px;
        height: 20px;
        border-radius: 999px;
        border: 1px solid rgba(11, 21, 48, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 600;
        color: #111529;
        background: radial-gradient(
          circle at 30% 0,
          rgba(255, 255, 255, 0.7),
          transparent 55%
        );
      }

      .process-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 8px;
      }

      .process-copy {
        font-size: 0.9rem;
        color: var(--text-muted);
        max-width: 20rem;
        line-height: 1.72;
      }

      /* OPERATIONAL STANDARDS */
      .standards {
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 2.5fr);
        gap: 32px;
        align-items: flex-start;
      }

      .standards-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 10px;
      }

      .standard-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 0.94rem;
      }

      .standard-check {
        margin-top: 4px;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.68rem;
        color: #1a9a62;
      }

      .standard-text {
        color: var(--text-main);
      }

      .standards-card {
        border-radius: var(--radius-md);
        border: 1px solid rgba(225, 229, 240, 0.9);
        background: #ffffff;
        padding: 16px 18px 14px;
      }

      .standards-card-title {
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 6px;
      }

      .standards-card-body {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: 14px;
      }

      .standards-meta {
        font-size: 0.78rem;
        color: var(--text-muted);
      }

      /* HANDLING & DELIVERY */
      .handling-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 20px;
        margin-top: 28px;
      }

      .handling-item {
        border-radius: 14px;
        border: 1px solid var(--border-subtle);
        background: #ffffff;
        padding: 16px 14px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .handling-icon {
        width: 22px;
        height: 22px;
        border-radius: 999px;
        background: rgba(11, 21, 48, 0.04);
        border: 1px solid rgba(11, 21, 48, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        color: var(--navy);
      }

      .handling-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--navy);
      }

      .handling-copy {
        font-size: 0.86rem;
        color: var(--text-muted);
        line-height: 1.72;
      }

      /* SERVICE AREA */
      .coverage {
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 2.7fr);
        gap: 32px;
        align-items: stretch;
      }

      .coverage-body {
        font-size: 0.94rem;
        color: var(--text-muted);
        margin-top: 16px;
        max-width: 34rem;
        line-height: 1.72;
      }

      .coverage-points {
        margin-top: 10px;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .coverage-points li {
        font-size: 0.92rem;
        color: var(--text-main);
      }

      .coverage-cards-label {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 12px;
      }

      .coverage-cards-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .coverage-card {
        border-radius: var(--radius-md);
        padding: 14px 16px;
        background: #f9fafb;
        border: 1px solid var(--border-subtle);
        border-top-width: 3px;
        border-top-style: solid;
        color: var(--text-main);
      }

      .coverage-card--primary {
        border-top-color: #F36B2A;
      }

      .coverage-card--extended {
        border-top-color: #64748b;
      }

      .coverage-card-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 6px;
      }

      .coverage-card-body {
        font-size: 0.86rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      .coverage-card-body p {
        margin: 0 0 4px;
      }

      .coverage-card-body p:last-child {
        margin-bottom: 0;
      }

      /* CONTACT / CTA */
      .cta-block {
        margin-top: 40px;
        border-radius: var(--radius-lg);
        padding: 32px 26px 26px;
        background: #ffffff;
        color: var(--text-main);
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 2.4fr);
        gap: 28px;
        align-items: flex-start;
      }

      .cta-heading {
        font-size: 1.3rem;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }

      .cta-text {
        font-size: 0.94rem;
        color: var(--text-muted);
        margin-bottom: 24px;
        max-width: 34rem;
        line-height: 1.74;
      }

      .cta-inline {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
      }

      .cta-inline-note {
        font-size: 0.8rem;
        color: var(--text-muted);
      }

      .cta-inline .btn-primary {
        box-shadow: 0 12px 32px rgba(255, 158, 83, 0.4);
      }

      .form-card {
        border-radius: 14px;
        background: #ffffff;
        border: 1px solid var(--border-subtle);
        padding: 14px 14px 12px;
      }

      .form-title {
        font-size: 0.86rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 8px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .form-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .form-field label {
        font-size: 0.78rem;
        color: var(--text-muted);
      }

      .form-field input,
      .form-field select,
      .form-field textarea {
        width: 100%;
        border-radius: 9px;
        border: 1px solid rgba(126, 147, 212, 0.7);
        padding: 7px 9px;
        background: #ffffff;
        color: #1b2340;
        font-size: 0.82rem;
        font-family: inherit;
      }

      .form-field textarea {
        resize: vertical;
        min-height: 60px;
        grid-column: 1 / -1;
      }

      .form-field input::placeholder,
      .form-field textarea::placeholder {
        color: #6b7280;
      }

      .form-footer {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        justify-content: space-between;
      }

      .form-note {
        font-size: 0.7rem;
        color: var(--text-muted);
      }

      .form-success {
        font-size: 0.8rem;
        color: var(--text-main);
        margin-bottom: 8px;
        display: none;
      }

      .form-success.is-visible {
        display: block;
      }

      .btn-form {
        padding: 8px 16px;
        border-radius: var(--radius-pill);
        border: none;
        cursor: pointer;
        background: linear-gradient(135deg, var(--orange), #ff9f5c);
        color: #ffffff;
        font-weight: 600;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .btn-form:hover {
        filter: brightness(1.04);
      }

      /* FOOTER */
      .footer {
        padding-top: 48px;
        font-size: 0.8rem;
        color: var(--text-muted);
      }

      .footer-inner {
        border-top: 1px solid var(--border-subtle);
        padding-top: 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: flex-start;
        justify-content: space-between;
      }

      .footer-block {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .footer-heading {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .footer-text {
        font-size: 0.8rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .footer-link {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-decoration: none;
      }

      .footer-link:hover {
        color: var(--navy);
      }

      /* RESPONSIVE */
      @media (max-width: 900px) {
        .hero-grid {
          grid-template-columns: minmax(0, 1.1fr);
        }

        .hero-panel {
          order: -1;
        }

        .standards,
        .coverage,
        .cta-block {
          grid-template-columns: minmax(0, 1fr);
        }

        .cta-block {
          padding: 18px 16px 16px;
        }

        /* Collapse nav to hamburger on tablet and mobile */
        .nav-links,
        .nav-cta {
          display: none;
        }

        .nav-toggle {
          display: inline-flex;
        }

        .nav-inner {
          padding: 10px 18px 10px;
        }

        .nav-menu-mobile.open {
          display: block;
        }

      }

      @media (max-width: 768px) {
        .brand img {
          height: 54px;
        }
      }

      @media (max-width: 720px) {
        .nav-inner {
          padding: 10px 14px 10px;
        }

        .nav-menu-mobile {
          padding: 0 14px 12px;
        }

        .nav-menu-mobile-inner {
          padding: 12px 10px 14px;
          gap: 2px;
        }

        .nav-menu-mobile a {
          padding: 10px 8px;
          font-size: 0.88rem;
        }

        .shell {
          padding-inline: 16px;
        }

        .process {
          grid-template-columns: minmax(0, 1fr);
        }

        .hero-actions {
          flex-direction: column;
          align-items: stretch;
        }

        .hero-actions .btn-primary,
        .hero-actions .btn-secondary {
          width: 100%;
          justify-content: center;
        }

        .hero-meta {
          gap: 10px;
        }
      }

      @media (max-width: 520px) {
        .form-grid,
        .handling-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .cta-block {
          gap: 18px;
        }

        .coverage-cards-grid {
          grid-template-columns: minmax(0, 1fr);
        }
      }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="nav-inner">
        <a href="#top" class="brand" aria-label="OnTask Logistics home">
          <img
            src="/new-ontask-logo.svg"
            alt="OnTask Logistics"
          />
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a class="nav-link" href="#how">How Service Works</a>
          <a class="nav-link" href="#standards">Operational Standards</a>
          <a class="nav-link" href="#coverage">Service Area</a>
        </nav>
        <a class="nav-cta" href="#consultation">Request Consultation</a>
        <button
          class="nav-toggle"
          type="button"
          aria-label="Toggle navigation"
          aria-expanded="false"
        >
          <span class="nav-toggle-bars">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
      <div class="nav-menu-mobile" id="navMobile">
        <div class="nav-menu-mobile-inner">
          <a href="#how">How Service Works</a>
          <a href="#standards">Operational Standards</a>
          <a href="#coverage">Service Area</a>
          <a href="#consultation">Request Consultation</a>
        </div>
      </div>
    </header>

    <main id="top" class="page">
      <div class="shell">
        <!-- Hero -->
        <section class="hero" aria-labelledby="hero-title">
          <div class="hero-grid">
            <div>
              <div class="eyebrow">
                <span class="eyebrow-pill">Scheduled courier logistics</span>
                <span class="eyebrow-text">Built for recurring routes</span>
              </div>
              <h1 id="hero-title" class="hero-title">
                Courier Routes That Work the Way Your Office Does
              </h1>
              <p class="hero-body">
                Built around your schedule, so pickups happen when expected, deliveries are documented, and your team isn’t chasing updates.
              </p>
              <p class="hero-body">
                OnTask Logistics provides scheduled courier routes across
                Philadelphia and surrounding counties. Service is structured
                around predictable pickup schedules, documented proof of
                delivery, and consistent communication that reduces operational
                friction for your staff.
              </p>
              <div class="hero-actions">
                <a class="btn-primary" href="#consultation">
                  Request Consultation
                </a>
                <a class="btn-secondary" href="#coverage">View Service Area</a>
                <p class="hero-actions-note">
                  Most route consultations take about 10 minutes.
                </p>
              </div>
            </div>
            <aside class="hero-panel" aria-label="Route overview example">
              <div class="panel-header">
                <div class="panel-label">Typical Active Route</div>
                <div class="panel-pill">On Schedule</div>
              </div>
              <div class="route-card">
                <div class="route-grid" aria-label="Route summary details">
                  <div class="route-row">
                    <div class="route-label">Route</div>
                    <div class="route-value">Morning Route 04</div>
                  </div>
                  <div class="route-row">
                    <div class="route-label">Status</div>
                    <div class="route-value">On Schedule</div>
                  </div>
                  <div class="route-row">
                    <div class="route-label">Coverage Area</div>
                    <div class="route-value">
                      University City &amp; Center City
                    </div>
                  </div>
                  <div class="route-row">
                    <div class="route-label">Pickup Window</div>
                    <div class="route-value">8:00 AM &ndash; 10:30 AM</div>
                  </div>
                  <div class="route-row">
                    <div class="route-label">Stops</div>
                    <div class="route-value">9 offices</div>
                  </div>
                  <div class="route-row">
                    <div class="route-label">Contents</div>
                    <div class="route-value">Documents and materials</div>
                  </div>
                </div>
              </div>
              <p class="panel-footnote">
                <strong>Structured courier routes designed to support predictable office operations.</strong>
                OnTask operates as an extension of your routine, supporting
                laboratories, clinics, multi-site practices, and professional
                offices that rely on consistent courier coverage.
              </p>
            </aside>
          </div>
          <div class="hero-meta">
            <div class="hero-meta-item">
              <span class="dot"></span>
              <span>Designed for recurring scheduled pickups</span>
            </div>
            <div class="hero-meta-item">
              <span>Timestamped proof of delivery for every stop</span>
            </div>
          </div>
        </section>

        <!-- How route service works -->
        <section
          id="how"
          class="section"
          aria-labelledby="how-title"
        >
          <div class="section-header">
            <div class="section-eyebrow">Process overview</div>
            <h2 id="how-title" class="section-title">
              How Service Works
            </h2>
            <p class="section-body">
              OnTask is built around predictable routines. Each route is set up
              through a short onboarding process that captures your pickup
              requirements and translates them into consistent courier coverage.
              Each route is structured so your staff knows when pickups occur,
              how deliveries are documented, and who to contact if questions
              arise.
            </p>
          </div>
          <div class="process" aria-label="How route service works">
            <article class="process-card">
              <div class="process-label">
                <span class="process-number">1</span>
                <span>Route consultation</span>
              </div>
              <h3 class="process-title">Route Consultation</h3>
              <p class="process-copy">
                We review pickup frequency, locations, and handoff procedures to
                design a recurring pickup schedule that fits your workflow.
              </p>
            </article>

            <article class="process-card">
              <div class="process-label">
                <span class="process-number">2</span>
                <span>Defined schedule</span>
              </div>
              <h3 class="process-title">Defined Schedule</h3>
              <p class="process-copy">
                Your office is assigned to a recurring route with defined pickup
                windows aligned with your operating hours and deadlines.
              </p>
            </article>

            <article class="process-card">
              <div class="process-label">
                <span class="process-number">3</span>
                <span>Documented completion</span>
              </div>
              <h3 class="process-title">Documented Completion</h3>
              <p class="process-copy">
                Each completed stop is logged with a timestamp and recipient
                verification, providing clear proof of delivery for your
                records.
              </p>
            </article>
          </div>
        </section>

        <!-- Handling and Delivery Protocol -->
        <section
          class="section section--muted"
          aria-labelledby="handling-title"
        >
          <div class="section-header">
            <div class="section-eyebrow">Handling &amp; delivery</div>
            <h2 id="handling-title" class="section-title">
              Handling and Delivery Protocol
            </h2>
            <p class="section-body">
              Every pickup follows a structured handling process designed to
              maintain documentation, accountability, and delivery verification.
            </p>
          </div>
          <div
            class="handling-grid"
            aria-label="Handling and delivery protocol steps"
          >
            <article class="handling-item">
              <div class="handling-icon">1</div>
              <h3 class="handling-title">Pickup Confirmation</h3>
              <p class="handling-copy">
                Items are collected from designated staff during the assigned
                pickup window and logged at the point of transfer.
              </p>
            </article>
            <article class="handling-item">
              <div class="handling-icon">2</div>
              <h3 class="handling-title">Secure Transport</h3>
              <p class="handling-copy">
                Items move along a defined route designed to maintain
                accountability and minimize unnecessary handling.
              </p>
            </article>
            <article class="handling-item">
              <div class="handling-icon">3</div>
              <h3 class="handling-title">Delivery Verification</h3>
              <p class="handling-copy">
                Each delivery stop is completed with timestamped confirmation and
                recipient verification when required.
              </p>
            </article>
            <article class="handling-item">
              <div class="handling-icon">4</div>
              <h3 class="handling-title">Proof of Delivery</h3>
              <p class="handling-copy">
                Delivery completion is documented with time, location, and
                recipient details so clients maintain a clear record.
              </p>
            </article>
          </div>
        </section>

        <!-- Operational standards -->
        <section
          id="standards"
          class="section"
          aria-labelledby="standards-title"
        >
          <div class="standards">
            <div>
              <div class="section-header">
                <div class="section-eyebrow">Reliability</div>
                <h2 id="standards-title" class="section-title">
                  Operational Standards
                </h2>
              </div>
              <ul class="standards-list">
                <li class="standard-item">
                  <span class="standard-check">✓</span>
                  <span class="standard-text">Defined pickup windows</span>
                </li>
                <li class="standard-item">
                  <span class="standard-check">✓</span>
                  <span class="standard-text">Consistent route execution</span>
                </li>
                <li class="standard-item">
                  <span class="standard-check">✓</span>
                  <span class="standard-text">
                    Documented proof of delivery for every completed stop
                  </span>
                </li>
                <li class="standard-item">
                  <span class="standard-check">✓</span>
                  <span class="standard-text">
                    Direct communication with an assigned contact
                  </span>
                </li>
                <li class="standard-item">
                  <span class="standard-check">✓</span>
                  <span class="standard-text">
                    Service within established coverage areas
                  </span>
                </li>
                <li class="standard-item">
                  <span class="standard-check">✓</span>
                  <span class="standard-text">
                    Clear chain of custody for documents and materials
                  </span>
                </li>
              </ul>
            </div>
            <aside class="standards-card">
              <div class="standards-card-title">Additional coverage</div>
              <p class="standards-card-body">
                While many routes support medical offices and clinics, OnTask can also
                support structured courier needs for other professional offices.
                This includes document delivery, inter-office transport, and
                other recurring movements that benefit from defined schedules
                and documented completion.
              </p>
              <p class="standards-meta">
                Engagements are typically scoped and scheduled in advance to
                support predictable courier routes. One-time deliveries may be
                accommodated when they align with existing routes or operational
                availability.
              </p>
            </aside>
          </div>
        </section>

        <!-- Who we work with -->
        <section
          class="section section--muted"
          aria-labelledby="clients-title"
        >
          <div class="section-header">
            <div class="section-eyebrow">Client types</div>
            <h2 id="clients-title" class="section-title">
              Organizations That Benefit From Structured Courier Routes
            </h2>
          </div>
          <p class="coverage-body" style="margin-top: 16px; margin-bottom: 32px;">
            OnTask Logistics supports organizations that require consistent,
            scheduled document and materials movement between locations. Service
            is designed around predictable courier routes while still supporting
            occasional one-off delivery needs when required.
          </p>
          <div class="coverage-cards-grid" aria-label="Who we work with">
            <div class="coverage-card coverage-card--primary">
              <div class="coverage-card-title">Medical Practices</div>
              <div class="coverage-card-body">
                <p>
                  Recurring document and materials transfers for clinics and
                  multi-location practices.
                </p>
              </div>
            </div>
            <div class="coverage-card coverage-card--primary">
              <div class="coverage-card-title">Professional Offices</div>
              <div class="coverage-card-body">
                <p>
                  Scheduled courier support for law firms, accounting offices,
                  and other professional services.
                </p>
              </div>
            </div>
            <div class="coverage-card coverage-card--primary">
              <div class="coverage-card-title">Multi-Location Businesses</div>
              <div class="coverage-card-body">
                <p>
                  Reliable internal transfers between offices that benefit from
                  predictable courier routes.
                </p>
              </div>
            </div>
            <div class="coverage-card coverage-card--extended">
              <div class="coverage-card-title">Administrative Teams</div>
              <div class="coverage-card-body">
                <p>
                  Organizations that need consistent document movement without
                  managing in-house delivery.
                </p>
              </div>
            </div>
          </div>
        </section>

        <section class="section" aria-labelledby="operations-title">
          <div class="section-header">
            <div class="section-eyebrow">Operating approach</div>
            <h2 id="operations-title" class="section-title">
              Local Courier Operations Built for Predictable Workflows
            </h2>
          </div>
          <p class="coverage-body">
            OnTask Logistics is a Philadelphia based courier service built
            around structured, recurring delivery routes for offices and
            professional organizations. The service is designed for teams that
            rely on predictable document and materials movement between
            locations but do not want to manage in-house delivery operations.
          </p>
          <p class="coverage-body">
            Routes are planned with defined pickup windows, documented handoffs,
            and consistent delivery verification. Each route is managed with
            clear communication and a single operational point of contact so
            your staff always knows who is responsible for the delivery process.
          </p>
          <p class="coverage-body">
            This structured approach allows organizations to maintain dependable
            logistics coverage while keeping operations simple, accountable, and
            predictable.
          </p>
        </section>

        <!-- Service area -->
        <section
          id="coverage"
          class="section section--muted"
          aria-labelledby="coverage-title"
        >
          <div class="coverage">
            <div>
              <div class="section-header">
                <div class="section-eyebrow">Service area</div>
                <h2 id="coverage-title" class="section-title">
                  Route-based courier coverage across the Philadelphia region.
                </h2>
              </div>
              <p class="coverage-body">
                Route planning is centered on offices, clinics, and
                professional practices that require dependable recurring
                courier coverage. OnTask focuses on a defined geography to
                maintain schedule integrity and consistent route execution.
                Service is structured around defined coverage areas that allow
                for predictable route planning and reliable pickup scheduling.
                Coverage is reviewed based on route structure, operational fit,
                and scheduling availability. Coverage depends on route structure
                and operational availability.
              </p>
            </div>
            <div>
              <div class="coverage-cards-label">Service Coverage</div>
              <div class="coverage-cards-grid" aria-label="Coverage by area">
                <div class="coverage-card coverage-card--primary">
                  <div class="coverage-card-title">Philadelphia</div>
                  <div class="coverage-card-body">
                    <p>Primary structured courier routes</p>
                    <p>Same-day pickups available</p>
                  </div>
                </div>
                <div class="coverage-card coverage-card--primary">
                  <div class="coverage-card-title">Montgomery County</div>
                  <div class="coverage-card-body">
                    <p>Recurring clinic and lab routes</p>
                    <p>Suburban coverage focus</p>
                  </div>
                </div>
                <div class="coverage-card coverage-card--primary">
                  <div class="coverage-card-title">Delaware County</div>
                  <div class="coverage-card-body">
                    <p>Scheduled courier service for medical offices</p>
                  </div>
                </div>
                <div class="coverage-card coverage-card--extended">
                  <div class="coverage-card-title">South Jersey</div>
                  <div class="coverage-card-body">
                    <p>Limited coverage</p>
                    <p>Available for established routes</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Final CTA -->
        <section
          id="consultation"
          class="section"
          aria-labelledby="cta-title"
        >
          <div class="cta-block">
            <div>
              <div class="section-eyebrow">Route consultation</div>
              <h2 id="cta-title" class="cta-heading">
                Structured courier service for offices that run on schedule.
              </h2>
              <p class="cta-text">
                If your office needs consistent pickups, predictable courier
                scheduling, and documented delivery records, OnTask Logistics
                provides structured route service designed for offices, clinics,
                and other professional practices.
              </p>
              <p class="cta-text">
                New route consultations are currently being scheduled for
                organizations seeking consistent weekly courier coverage.
              </p>
              <div class="cta-inline">
                <a href="#consultation-form" class="btn-primary">
                  Request Consultation
                </a>
                <p class="cta-inline-note">
                  Share your pickup locations and frequency. We&#8217;ll review
                  your routing needs and respond with a proposed route
                  structure and coverage confirmation.
                </p>
              </div>
            </div>
            <form
              id="consultation-form"
              class="form-card"
              name="consultation"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              action="/thank-you/"
            >
              <div class="form-title">Request a consultation</div>
              <input type="hidden" name="form-name" value="consultation" />
              <div style="display:none;">
                <label for="bot-field">Do not fill this out if you are human</label>
                <input id="bot-field" name="bot-field" type="text" />
              </div>
              <div class="form-grid">
                <div class="form-field">
                  <label for="consultation-name">Name</label>
                  <input
                    id="consultation-name"
                    name="name"
                    type="text"
                    required
                    placeholder="Your name"
                  />
                </div>
                <div class="form-field">
                  <label for="consultation-email">Email</label>
                  <input
                    id="consultation-email"
                    name="email"
                    type="email"
                    required
                    placeholder="name@example.com"
                  />
                </div>
                <div class="form-field">
                  <label for="consultation-phone">Phone</label>
                  <input
                    id="consultation-phone"
                    name="phone"
                    type="tel"
                    placeholder="(555) 000-0000"
                  />
                </div>
                <div class="form-field">
                  <label for="consultation-organization">Organization</label>
                  <input
                    id="consultation-organization"
                    name="organization"
                    type="text"
                    placeholder="Company or practice name"
                  />
                </div>
                <div class="form-field">
                  <label for="consultation-service-area">Service Area</label>
                  <select
                    id="consultation-service-area"
                    name="service_area"
                    required
                  >
                    <option value="">Select a service area</option>
                    <option value="Philadelphia">Philadelphia</option>
                    <option value="Montgomery County">Montgomery County</option>
                    <option value="Delaware County">Delaware County</option>
                    <option value="South Jersey">South Jersey</option>
                    <option value="Not sure">Not sure</option>
                  </select>
                </div>
                <div class="form-field" style="grid-column: 1 / -1">
                  <label for="consultation-message">Message</label>
                  <textarea
                    id="consultation-message"
                    name="message"
                    rows="4"
                    minlength="10"
                    placeholder="Briefly describe your pickup needs and schedule."
                  ></textarea>
                </div>
              </div>
              <div class="form-footer">
                <p class="form-success" aria-live="polite" hidden>
                  Your consultation request has been received. We will follow up
                  shortly.
                </p>
                <p class="form-note">
                  Submitted details are used only to respond to your inquiry.
                </p>
                <button type="submit" class="btn-form">
                  Request Consultation
                </button>
                <p class="form-note">
                  After you submit, our team reviews your request and follows up shortly.
                </p>
              </div>
            </form>
          </div>
        </section>

      </div>
    </main>
    <Footer />

    <script>
      // Mobile navigation toggle
      (function () {
        var toggle = document.querySelector(".nav-toggle");
        var mobileMenu = document.getElementById("navMobile");

        if (!toggle || !mobileMenu) return;

        toggle.addEventListener("click", function () {
          var isOpen = mobileMenu.classList.toggle("open");
          toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });

        mobileMenu.addEventListener("click", function (event) {
          if (event.target.tagName.toLowerCase() === "a") {
            mobileMenu.classList.remove("open");
            toggle.setAttribute("aria-expanded", "false");
          }
        });
      })();

      // Footer year (not shown, but can be used if needed)
      (function () {
        var yearEl = document.getElementById("year");
        if (yearEl) {
          yearEl.textContent = new Date().getFullYear();
        }
      })();
    </script>
  </body>
</html>

