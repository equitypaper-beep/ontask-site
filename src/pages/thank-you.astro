---
import Footer from "../components/Footer.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>Consultation Request Received | OnTask Logistics LLC</title>
    <meta
      name="description"
      content="Confirmation page for OnTask Logistics LLC route consultation requests."
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/ontask-favicon-main.png"
    />
    <link rel="apple-touch-icon" href="/ontask-favicon-main.png" />
    <style>
      :root {
        --navy: #0b1530;
        --text-main: #111827;
        --text-muted: #4b5563;
        --bg-body: #f9fafb;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background: var(--bg-body);
        color: var(--text-main);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      main {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .shell {
        max-width: 720px;
        margin: 0 auto;
        padding: 64px 20px;
        text-align: center;
      }

      .page-title {
        font-size: 1.5rem;
        letter-spacing: -0.02em;
        color: var(--navy);
        margin-bottom: 10px;
      }

      .page-body {
        font-size: 0.94rem;
        color: var(--text-muted);
        max-width: 40rem;
        margin: 0 auto;
      }

      .page-body p + p {
        margin-top: 10px;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="shell">
        <h1 class="page-title">Consultation request received.</h1>
        <div class="page-body">
          <p>Thank you for contacting OnTask Logistics. Your consultation request has been received.</p>

          <p>We review route availability based on service location, pickup frequency, and route fit. We’ll follow up shortly with next steps.</p>

          <p>If your request is time sensitive, contact us at info@ontasklogistics.com.</p>
          <p>
            <a href="/">Back to OnTask Logistics</a>
          </p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

