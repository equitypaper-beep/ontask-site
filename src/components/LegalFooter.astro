---
---
<footer class="legal-footer" aria-label="Site navigation">
  <div class="legal-footer-inner">
    <a href="/" class="legal-footer-back">Back to OnTask Logistics</a>
    <p class="legal-footer-cta">
      Questions about our courier routes or service coverage?
    </p>
    <a href="/#consultation" class="legal-footer-btn">Request a Consultation</a>
  </div>
</footer>

<style>
  .legal-footer {
    border-top: 1px solid var(--border-subtle, #e1e5f0);
    margin-top: 48px;
    padding-top: 32px;
    padding-bottom: 24px;
  }

  .legal-footer-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .legal-footer-back {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--navy, #0b1530);
    text-decoration: none;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .legal-footer-back:hover {
    text-decoration: underline;
  }

  .legal-footer-cta {
    font-size: 0.94rem;
    color: var(--text-muted, #4b5563);
    margin: 0;
    line-height: 1.5;
  }

  .legal-footer-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    border-radius: 999px;
    border: none;
    background: #F36B2A;
    color: #ffffff;
    font-weight: 600;
    font-size: 0.86rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
  }

  .legal-footer-btn:hover {
    background: #f57a3d;
    filter: brightness(1.02);
  }
</style>
