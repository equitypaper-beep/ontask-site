---
<footer class="site-footer" role="contentinfo">
  <div class="site-footer-inner">
    <nav class="site-footer-nav" aria-label="Footer navigation">
      <a href="/">Home</a>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/terms/">Terms of Use</a>
    </nav>
    <div class="site-footer-contact">
      <a href="mailto:info@ontasklogistics.com" class="site-footer-email">
        info@ontasklogistics.com
      </a>
    </div>
    <p class="site-footer-area">
      Philadelphia, Montgomery County, Delaware County, Limited South Jersey
    </p>
    <p class="site-footer-tagline">
      Structured Courier Routes for Philadelphia Practices
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-subtle, #e1e5f0);
    padding: 20px 16px 24px;
    margin-top: 32px;
    background: transparent;
  }

  .site-footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .site-footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 20px;
  }

  .site-footer-nav a {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted, #6b7280);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .site-footer-nav a:hover {
    color: var(--navy, #0b1530);
  }

  .site-footer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .site-footer-email {
    font-size: 0.8rem;
    color: var(--text-muted, #6b7280);
    text-decoration: none;
  }

  .site-footer-email:hover {
    color: var(--navy, #0b1530);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer-area {
    font-size: 0.78rem;
    color: var(--text-muted, #6b7280);
    margin: 0;
    line-height: 1.5;
    max-width: 32rem;
  }

  .site-footer-tagline {
    font-size: 0.76rem;
    color: var(--text-muted, #6b7280);
    margin: 0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (min-width: 640px) {
    .site-footer {
      padding: 20px 20px 28px;
      margin-top: 40px;
    }

    .site-footer-inner {
      gap: 12px;
    }
  }
</style>
