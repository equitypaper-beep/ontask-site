---
<footer class="site-footer" role="contentinfo">
  <div class="site-footer-inner">
    <div class="site-footer-grid">
      <div class="site-footer-col">
        <div class="site-footer-heading">OnTask Logistics LLC</div>
        <div class="site-footer-line">Philadelphia, Pennsylvania</div>
        <a href="mailto:info@ontasklogistics.com" class="site-footer-email">
          info@ontasklogistics.com
        </a>
      </div>
      <div class="site-footer-col">
        <div class="site-footer-heading">Service Area</div>
        <div class="site-footer-line">Philadelphia</div>
        <div class="site-footer-line">Montgomery County</div>
        <div class="site-footer-line">Delaware County</div>
        <div class="site-footer-line">Limited South Jersey</div>
      </div>
      <div class="site-footer-col">
        <div class="site-footer-heading">Links</div>
        <nav class="site-footer-links" aria-label="Footer navigation">
          <a href="/privacy/">Privacy Policy</a>
          <a href="/terms/">Terms of Use</a>
        </nav>
      </div>
    </div>
    <p class="site-footer-tagline">
      Structured Courier Routes for Philadelphia Practices
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-subtle, #e1e5f0);
    padding: 32px 20px 32px;
    margin-top: 48px;
    background: transparent;
  }

  .site-footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .site-footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .site-footer-col {
    font-size: 0.9rem;
    color: var(--text-muted, #6b7280);
    line-height: 1.6;
  }

  .site-footer-heading {
    font-weight: 600;
    margin-bottom: 8px;
  }

  .site-footer-line {
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .site-footer-email {
    font-size: 0.8rem;
    color: var(--text-muted, #6b7280);
    text-decoration: none;
  }

  .site-footer-email:hover {
    color: var(--navy, #0b1530);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .site-footer-links a {
    font-size: 0.8rem;
    color: var(--text-muted, #6b7280);
    text-decoration: none;
  }

  .site-footer-links a:hover {
    color: var(--navy, #0b1530);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer-tagline {
    font-size: 0.76rem;
    color: var(--text-muted, #6b7280);
    margin: 16px 0 0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
  }

  @media (min-width: 640px) {
    .site-footer-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
