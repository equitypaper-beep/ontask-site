---
---
<footer class="site-footer" role="contentinfo">
  <div class="site-footer-inner">
    <nav class="site-footer-nav" aria-label="Footer navigation">
      <a href="/">Home</a>
      <a href="/consultation">Consultation</a>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/terms/">Terms of Use</a>
    </nav>
    <div class="site-footer-contact">
      <span class="site-footer-company">OnTask Logistics LLC</span>
      <a href="mailto:info@ontasklogistics.com" class="site-footer-email">info@ontasklogistics.com</a>
    </div>
    <p class="site-footer-area">
      Philadelphia • Montgomery County • Delaware County • Limited South Jersey
    </p>
    <p class="site-footer-tagline">
      Structured Courier Routes for Philadelphia Practices
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-subtle, #e1e5f0);
    padding: 32px 20px 40px;
    margin-top: 0;
    background: var(--bg-body, #f9fafb);
  }

  .site-footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .site-footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 24px;
  }

  .site-footer-nav a {
    font-size: 0.86rem;
    font-weight: 500;
    color: var(--text-muted, #374151);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-footer-nav a:hover {
    color: var(--navy, #0b1530);
  }

  .site-footer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .site-footer-company {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--navy, #0b1530);
    letter-spacing: 0.02em;
  }

  .site-footer-email {
    font-size: 0.88rem;
    color: var(--text-muted, #374151);
    text-decoration: none;
  }

  .site-footer-email:hover {
    color: var(--navy, #0b1530);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer-area {
    font-size: 0.82rem;
    color: var(--text-muted, #374151);
    margin: 0;
    line-height: 1.5;
    max-width: 36rem;
  }

  .site-footer-tagline {
    font-size: 0.8rem;
    color: var(--text-muted, #374151);
    margin: 0;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  @media (min-width: 640px) {
    .site-footer {
      padding: 40px 24px 48px;
    }

    .site-footer-inner {
      gap: 24px;
    }

    .site-footer-nav {
      gap: 16px 32px;
    }

    .site-footer-nav a {
      font-size: 0.88rem;
    }
  }
</style>
